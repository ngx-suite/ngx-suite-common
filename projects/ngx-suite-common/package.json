{
  "name": "@ngx-suite/common",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngx-suite/ngx-suite-common.git",
    "directory": "projects/ngx-suite-common"
  },
  "peerDependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/material": "^21.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    "./styles/*": {
      "sass": "./styles/*"
    }
  },
  "scripts": {
    "next-preminor-version": "npm version preminor --preid=SNAPSHOT",
    "next-snapshot-version": "npm version prerelease --preid=SNAPSHOT",
    "next-major-version": "npm version major",
    "next-minor-version": "npm version minor",
    "next-patch-version": "npm version patch",
    "version": "echo $npm_package_version"
  },
  "sideEffects": false
}
